    /// </summary>
    public JsonSerializerOptions JsonSerializerOptions { get; set; } = new()
    {
        PropertyNameCaseInsensitive = true
    };
    
    /// <summary>
    /// Whether to automatically inject application context as first parameter
    /// </summary>
    public bool InjectApplicationContext { get; set; } = true;
    
    /// <summary>
    /// Name of the application context table type (if using structured parameters)
    /// </summary>
    public string ApplicationContextTableType { get; set; } = "ApplicationContext";
}

/// <summary>
