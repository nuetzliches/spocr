/// <summary>
/// Modern SpocR database context with improved transaction management and DI integration
/// </summary>
public interface ISpocRDbContext : IAsyncDisposable
{
    /// <summary>
    /// Gets the configuration options for this context
    /// </summary>
    SpocRDbContextOptions Options { get; }
    
    /// <summary>
    /// Gets the underlying SQL connection
    /// </summary>
    SqlConnection Connection { get; }
    
    /// <summary>
    /// Gets the current application context parameters (e.g., UserId, TenantId)
    /// </summary>
    IApplicationContext ApplicationContext { get; }
    
    /// <summary>
    /// Begins a new database transaction
    /// </summary>
    /// <param name="isolationLevel">The isolation level for the transaction</param>
    /// <param name="cancellationToken">Cancellation token</param>
    /// <returns>A new transaction instance</returns>
    Task<ISpocRTransaction> BeginTransactionAsync(
        IsolationLevel isolationLevel = IsolationLevel.ReadCommitted,
        CancellationToken cancellationToken = default);
    
    /// <summary>
    /// Executes a stored procedure with automatic parameter mapping
    /// </summary>
    /// <typeparam name="TInput">Input parameter type</typeparam>
    /// <typeparam name="TResult">Result type</typeparam>
    /// <param name="procedureName">Name of the stored procedure</param>
    /// <param name="input">Input parameters</param>
    /// <param name="transaction">Optional transaction</param>
    /// <param name="cancellationToken">Cancellation token</param>
    /// <returns>Execution result</returns>
    Task<TResult> ExecuteStoredProcedureAsync<TInput, TResult>(
        string procedureName,
        TInput input,
        ISpocRTransaction transaction = null,
        CancellationToken cancellationToken = default);
}

/// <summary>
/// Modern transaction interface with async disposal
/// </summary>
public interface ISpocRTransaction : IAsyncDisposable
{
    /// <summary>
    /// Gets the underlying SQL transaction
    /// </summary>
    SqlTransaction SqlTransaction { get; }
    
    /// <summary>
    /// Commits the transaction
    /// </summary>
    /// <param name="cancellationToken">Cancellation token</param>
    Task CommitAsync(CancellationToken cancellationToken = default);
    
    /// <summary>
    /// Rolls back the transaction
    /// </summary>
    /// <param name="cancellationToken">Cancellation token</param>
    Task RollbackAsync(CancellationToken cancellationToken = default);
}

/// <summary>
/// Application context for passing user-specific parameters
/// </summary>
public interface IApplicationContext
{
    /// <summary>
    /// Gets the current user ID
    /// </summary>
    string UserId { get; }
    
    /// <summary>
    /// Gets the current tenant ID (for multi-tenant applications)
    /// </summary>
    string TenantId { get; }
    
    /// <summary>
    /// Gets additional context parameters
    /// </summary>
    IReadOnlyDictionary<string, object> Parameters { get; }
}

/// <summary>
/// Configuration options for SpocR database context
/// </summary>
public class SpocRDbContextOptions
{
    /// <summary>
    /// Command timeout in seconds (default: 30)
    /// </summary>
    public int CommandTimeout { get; set; } = 30;
    
    /// <summary>
