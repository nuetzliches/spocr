    public string TenantId { get; init; } = string.Empty;
    public IReadOnlyDictionary<string, object> Parameters { get; init; } = new Dictionary<string, object>();
}

/// <summary>
/// Modern SpocR database context implementation
/// </summary>
public class SpocRDbContext : ISpocRDbContext
{
    private readonly List<ISpocRTransaction> _activeTransactions = new();
    private bool _disposed;

    public SpocRDbContextOptions Options { get; }
    public SqlConnection Connection { get; }
    public IApplicationContext ApplicationContext { get; }

    public SpocRDbContext(
        IConfiguration configuration,
        IOptions<SpocRDbContextOptions> options,
        IApplicationContext applicationContext)
    {
        Options = options.Value;
        ApplicationContext = applicationContext;
        
        var connectionString = configuration.GetConnectionString("{{ConnectionStringName}}") 
            ?? throw new InvalidOperationException("Connection string '{{ConnectionStringName}}' not found");
            
        Connection = new SqlConnection(connectionString);
    }

    public async Task<ISpocRTransaction> BeginTransactionAsync(
        IsolationLevel isolationLevel = IsolationLevel.ReadCommitted,
        CancellationToken cancellationToken = default)
    {
        if (Connection.State != ConnectionState.Open)
        {
            await Connection.OpenAsync(cancellationToken);
        }

        var sqlTransaction = (SqlTransaction)await Connection.BeginTransactionAsync(isolationLevel, cancellationToken);
        var transaction = new SpocRTransaction(sqlTransaction);
        
        _activeTransactions.Add(transaction);
        transaction.Disposed += () => _activeTransactions.Remove(transaction);
        
        return transaction;
    }

    public async Task<TResult> ExecuteStoredProcedureAsync<TInput, TResult>(
        string procedureName,
        TInput input,
        ISpocRTransaction transaction = null,
        CancellationToken cancellationToken = default)
    {
        if (Connection.State != ConnectionState.Open)
        {
            await Connection.OpenAsync(cancellationToken);
        }

        using var command = new SqlCommand(procedureName, Connection)
        {
            CommandType = CommandType.StoredProcedure,
            CommandTimeout = Options.CommandTimeout,
            Transaction = transaction?.SqlTransaction
        };

        // Add application context parameter if enabled
        {{#if InjectApplicationContext}}
        if (Options.InjectApplicationContext)
        {
            command.Parameters.Add(CreateApplicationContextParameter());
        }
        {{/if}}

        // Add input parameters using reflection or source generation
        AddInputParameters(command, input);

        // Execute and map results
        return await ExecuteAndMapResultAsync<TResult>(command, cancellationToken);
    }

    {{#if InjectApplicationContext}}
    private SqlParameter CreateApplicationContextParameter()
    {
        // Create structured parameter for application context
        var contextTable = new DataTable();
        contextTable.Columns.Add("UserId", typeof(string));
        contextTable.Columns.Add("TenantId", typeof(string));
        
        var row = contextTable.NewRow();
        row["UserId"] = ApplicationContext.UserId ?? DBNull.Value;
        row["TenantId"] = ApplicationContext.TenantId ?? DBNull.Value;
        contextTable.Rows.Add(row);

        return new SqlParameter("@ApplicationContext", SqlDbType.Structured)
        {
            TypeName = Options.ApplicationContextTableType,
            Value = contextTable
        };
    }
    {{/if}}

    private void AddInputParameters<TInput>(SqlCommand command, TInput input)
    {
        if (input == null) return;

        // This would be generated by SpocR for each stored procedure
        // Example implementation using reflection (production code would be generated)
        var properties = typeof(TInput).GetProperties();
        foreach (var property in properties)
        {
            var value = property.GetValue(input) ?? DBNull.Value;
            command.Parameters.AddWithValue($"@{property.Name}", value);
        }
    }

    private async Task<TResult> ExecuteAndMapResultAsync<TResult>(SqlCommand command, CancellationToken cancellationToken)
    {
        // This would be generated by SpocR for each result type
        // Example implementation (production code would be generated and type-safe)
        
        if (typeof(TResult) == typeof(int))
        {
            var result = await command.ExecuteScalarAsync(cancellationToken);
            return (TResult)(object)(result as int? ?? 0);
        }

        using var reader = await command.ExecuteReaderAsync(cancellationToken);
        
        // For now, return default - this would be replaced with generated mapping code
        return default(TResult);
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed) return;

        // Rollback any active transactions
        foreach (var transaction in _activeTransactions.ToArray())
        {
            await transaction.DisposeAsync();
        }
        _activeTransactions.Clear();

        if (Connection?.State == ConnectionState.Open)
        {
            await Connection.CloseAsync();
        }

        Connection?.Dispose();
        _disposed = true;
    }
}

/// <summary>
/// Modern transaction implementation with async disposal
/// </summary>
internal class SpocRTransaction : ISpocRTransaction
{
    private bool _disposed;
    private bool _completed;

    public SqlTransaction SqlTransaction { get; }
    public event Action Disposed;

    public SpocRTransaction(SqlTransaction sqlTransaction)
    {
        SqlTransaction = sqlTransaction ?? throw new ArgumentNullException(nameof(sqlTransaction));
    }

    public async Task CommitAsync(CancellationToken cancellationToken = default)
    {
        if (_disposed || _completed)
            throw new InvalidOperationException("Transaction has already been completed or disposed");

        await SqlTransaction.CommitAsync(cancellationToken);
        _completed = true;
    }

    public async Task RollbackAsync(CancellationToken cancellationToken = default)
    {
        if (_disposed || _completed)
            return; // Already completed or disposed

        try
        {
            await SqlTransaction.RollbackAsync(cancellationToken);
        }
        catch
        {
            // Ignore rollback errors on disposal
        }
        finally
        {
            _completed = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed) return;

        if (!_completed)
        {
            await RollbackAsync();
        }

        await SqlTransaction.DisposeAsync();
        _disposed = true;
        Disposed?.Invoke();
    }
}

